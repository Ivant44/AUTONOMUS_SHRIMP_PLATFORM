<?xml version="1.0" ?>
<robot name="SHRIM_MECHANICAL_BACKUP">

<material name="silver">
  <color rgba="0.700 0.700 0.700 1.000"/>
</material>

<link name="base_footprint"/>

<joint name="base_footprint_to_base_link" type="fixed">
  <parent link="base_footprint"/>
  <child link="base_link"/>
  <origin xyz="0 0 0" rpy="0 0 1.57079632679"/>
</joint>

<link name="base_link">
  <inertial>
    <origin xyz="0.0176847751641402 0.00229090870237322 0.05599845057809939" rpy="0 0 0"/>
    <mass value="38.09333724864147"/>
    <inertia ixx="0.7492582184178012" iyy="0.9519457840083874" izz="1.3350272647734087" ixy="-0.05331941683438979" iyz="0.013669358896541806" ixz="0.03806289907793825"/>
  </inertial>
  <visual>
    <origin xyz="0.479998 0.122814 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://shrimp_modu/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.029998 0.002814 0.12" rpy="0 0 0"/>
    <geometry>
      <box size="0.3 0.2 0.05"/> 
    </geometry>
  </collision>
</link>

<link name="camera_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.08 0.16 0.05"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.08 0.16 0.05"/>
    </geometry>
  </collision>
</link>

  <joint name="base_footprint_to_camera_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="camera_link"/>
    <origin xyz="0.02 0 0.30" rpy="0 0 0"/>
  </joint>

<link name="left_camera_frame"/>

<joint name="camera_link_to_left_camera_frame" type="fixed">
  <parent link="camera_link"/>
  <child link="left_camera_frame"/>
  <origin xyz="0 0.035 0" rpy="0 0 0"/>
</joint>

<link name="left_camera_optical_frame"/>

<joint name="left_camera_frame_to_left_camera_optical_frame" type="fixed">
  <parent link="left_camera_frame"/>
  <child link="left_camera_optical_frame"/>
  <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
</joint>

<link name="right_camera_frame"/>

<joint name="camera_link_to_right_camera_frame" type="fixed">
  <parent link="camera_link"/>
  <child link="right_camera_frame"/>
  <origin xyz="0 -0.035 0" rpy="0 0 0"/>
</joint>

<link name="right_camera_optical_frame"/>

<joint name="right_camera_frame_to_right_camera_optical_frame" type="fixed">
  <parent link="right_camera_frame"/>
  <child link="right_camera_optical_frame"/>
  <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
</joint>
  
