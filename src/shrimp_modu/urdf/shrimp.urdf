<joint name="base_link1_steering_front_joint" type="continuous">
  <origin xyz="0 -0.19 0.098158" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="base_link1steering_link1"/>
  <axis xyz="0.0 0.0 1.0"/>
</joint>

<joint name="base_link1_rear_left_wheel_base_link_joint" type="continuous">
  <origin xyz="-0.1785 0.077036 0.021662" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="base_link1rear_left_wheel1"/>
  <axis xyz="-1.0 0.0 -0.0"/>
</joint>

<joint name="base_link1_front_left_wheel_base_link_joint" type="continuous">
  <origin xyz="-0.1785 -0.097964 0.021662" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="base_link1front_left_wheel1"/>
  <axis xyz="-1.0 0.0 -0.0"/>
</joint>

<joint name="base_link1_front_right_wheel_base_link_joint" type="continuous">
  <origin xyz="0.179693 -0.097984 0.021662" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="base_link1front_right_wheel1"/>
  <axis xyz="1.0 -0.0 0.0"/>
</joint>

<joint name="base_link1_rear_right_wheel_base_link_joint" type="continuous">
  <origin xyz="0.179753 0.077036 0.021662" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="base_link1rear_right_wheel1"/>
  <axis xyz="1.0 -0.0 0.0"/>
</joint>

<joint name="base_link1_steering_back_joint" type="continuous">
  <origin xyz="0 0.19 0.108158" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="base_link1steering_link21"/>
  <axis xyz="0.0 0.0 1.0"/>
</joint>

<joint name="base_link1steering_link1_Revolucion_2" type="continuous">
  <origin xyz="0.005423 0.000233 -0.075556" rpy="0 0 0"/>
  <parent link="base_link1steering_link1"/>
  <child link="base_link1steering_link1front_wheel1"/>
  <axis xyz="-1 0 0"/>
</joint>

<joint name="base_link1steering_link21_Revolucion_2" type="continuous">
  <origin xyz="-0.005349 -0.000386 -0.085713" rpy="0 0 0"/>
  <parent link="base_link1steering_link21"/>
  <child link="base_link1steering_link21back_wheel1"/>
  <axis xyz="1 0 0"/>
</joint>

<ros2_control name="ShrimpSystem" type="system">
  <hardware>
    <plugin>gazebo_ros2_control/GazeboSystem</plugin>
  </hardware>

  <!-- RUEDAS DE TRACCIÓN (velocity) -->
  <joint name="base_link1_rear_left_wheel_base_link_joint">
    <command_interface name="velocity"/>
    <state_interface name="position">
      <param name="initial_value">0.0</param>
    </state_interface>
    <state_interface name="velocity"/>
  </joint>

  <joint name="base_link1_rear_right_wheel_base_link_joint">
    <command_interface name="velocity"/>
    <state_interface name="position">
      <param name="initial_value">0.0</param>
    </state_interface>
    <state_interface name="velocity"/>
  </joint>

  <joint name="base_link1_front_left_wheel_base_link_joint">
    <command_interface name="velocity"/>
    <state_interface name="position">
      <param name="initial_value">0.0</param>
    </state_interface>
    <state_interface name="velocity"/>
  </joint>

  <joint name="base_link1_front_right_wheel_base_link_joint">
    <command_interface name="velocity"/>
    <state_interface name="position">
      <param name="initial_value">0.0</param>
    </state_interface>
    <state_interface name="velocity"/>
  </joint>

  <!-- STEERING (position) -->
  <joint name="base_link1_steering_front_joint">
    <command_interface name="position"/>
    <state_interface name="position">
      <param name="initial_value">0.0</param>
    </state_interface>
  </joint>

  <joint name="base_link1_steering_back_joint">
    <command_interface name="position"/>
    <state_interface name="position">
      <param name="initial_value">0.0</param>
    </state_interface>
  </joint>

  <!-- RUEDAS DIRECCIONALES PASIVAS (velocity) -->
  <!-- NO se controlan activamente, pero necesitan interfaces para publicación de estados -->
  <joint name="base_link1steering_link1_Revolucion_2">
    <command_interface name="velocity"/>
    <state_interface name="position">
      <param name="initial_value">0.0</param>
    </state_interface>
    <state_interface name="velocity"/>
  </joint>

  <joint name="base_link1steering_link21_Revolucion_2">
    <command_interface name="velocity"/>
    <state_interface name="position">
      <param name="initial_value">0.0</param>
    </state_interface>
    <state_interface name="velocity"/>
  </joint>

</ros2_control>

<!-- REAR LEFT -->

<gazebo reference="base_link1rear_left_wheel1">
  <mu1>200.0</mu1>
  <mu2>200.0</mu2>
  <kp>1000000.0</kp>
  <kd>1.0</kd>
  <minDepth>0.001</minDepth>
</gazebo>

<gazebo reference="base_link1rear_right_wheel1">
  <mu1>200.0</mu1>
  <mu2>200.0</mu2>
  <kp>1000000.0</kp>
  <kd>1.0</kd>
  <minDepth>0.001</minDepth>
</gazebo>

<gazebo reference="base_link1front_left_wheel1">
  <mu1>200.0</mu1>
  <mu2>200.0</mu2>
  <kp>1000000.0</kp>
  <kd>1.0</kd>
  <minDepth>0.001</minDepth>
</gazebo>

<gazebo reference="base_link1front_right_wheel1">
  <mu1>200.0</mu1>
  <mu2>200.0</mu2>
  <kp>1000000.0</kp>
  <kd>1.0</kd>
  <minDepth>0.001</minDepth>
</gazebo>

<gazebo>
  <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
    <parameters>/home/ivan/ros2_ws/src/shrimp_modu/config/controllers.yaml</parameters>
  </plugin>
</gazebo>

<gazebo>
  <plugin name="ground_truth_p3d" filename="libgazebo_ros_p3d.so">
    <ros>
      <remapping>odom:=/odom_custom</remapping>
    </ros>
    <body_name>base_footprint</body_name>
    <update_rate>50.0</update_rate>
    <xyz_offset>0 0 0</xyz_offset>
    <rpy_offset>0 0 0</rpy_offset>
    <gaussian_noise>0.0</gaussian_noise>
  </plugin>
</gazebo>

<gazebo reference="camera_link">
  <sensor name="left_depth_camera" type="depth">
    <always_on>true</always_on>
    <update_rate>15</update_rate>
    <visualize>true</visualize>
    <pose>0 0.035 0 0 0 0</pose>
    <camera>
      <horizontal_fov>1.3962634</horizontal_fov>
      <image>
        <width>424</width>
        <height>240</height>
        <format>B8G8R8</format>
      </image>
      <depth_camera>
      </depth_camera>
      <clip>
        <near>0.15</near>
        <far>5.0</far>
      </clip>
      <noise>
        <type>gaussian</type>
        <mean>0.0</mean>
        <stddev>0.003</stddev>
      </noise>
    </camera>
    <plugin name="left_depth_camera_controller" filename="libgazebo_ros_camera.so">
      <camera_name>stereo</camera_name>
      <frame_name>left_camera_optical_frame</frame_name>
      <hack_baseline>0.07</hack_baseline>
      <min_depth>0.15</min_depth>
      <max_depth>5.0</max_depth>
    </plugin>
  </sensor>
</gazebo>

<gazebo>
  <ode>
    <solver>
      <type>quick</type>
      <iters>50</iters>
    </solver>
    <constraints>
      <cfm>0.0001</cfm>
      <erp>0.2</erp>
    </constraints>
  </ode>
</gazebo>

</robot>
